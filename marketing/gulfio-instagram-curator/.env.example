# Gulfio Instagram Curator — copy to .env and edit. ALL OPTIONAL.
# The toolkit is deterministic and needs no API keys. These just tune output.

# Brand name used across all deliverables (default: Gulfio)
# BRAND_NAME=Gulfio

# Where deliverables are written (default: ./out/<brand-slug>)
# OUT_DIR=

# Point at the news engine's learnings.json to use its self-learned best
# posting hour (default: ../gulfio-news-engine/state/learnings.json if present)
# LEARNINGS_FILE=
