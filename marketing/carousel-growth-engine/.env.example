# Carousel Growth Engine — copy to .env and fill in.
# Both Gemini and Upload-Post have free tiers (no credit card required).

# Google Gemini image generation — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override the image model (default: gemini-3.1-flash-image-preview)
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Upload-Post publishing + analytics — https://upload-post.com
UPLOADPOST_TOKEN=
UPLOADPOST_USER=

# Optional overrides
# CAROUSEL_HOME=/tmp/carousel
# UPLOADPOST_PLATFORMS=tiktok instagram
# SLIDE_WIDTH=768
# SLIDE_HEIGHT=1376
