# Instagram Curator — copy to .env and edit. ALL OPTIONAL.
# The toolkit is deterministic and needs no API keys. These just tune output.

# Brand name used across all deliverables (default: GrubPos)
# BRAND_NAME=GrubPos

# Where deliverables are written (default: ./out/<brand-slug>)
# OUT_DIR=

# Point at the carousel engine's learnings.json to use its self-learned best
# posting hour (default: ../carousel-growth-engine/state/learnings.json if present)
# LEARNINGS_FILE=
