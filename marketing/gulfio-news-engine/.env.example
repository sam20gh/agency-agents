# Gulfio News Engine — copy to .env and fill in.
# Gemini and Upload-Post both have free tiers (no credit card required).

# Google Gemini image generation — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override the image model (default: gemini-3.1-flash-image-preview)
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Gulfio content API (sent as the x-api-key header)
GULFIO_API_KEY=
# GULFIO_API_URL=https://api.gulfio.app/api/articles

# Upload-Post publishing + analytics — https://upload-post.com
UPLOADPOST_TOKEN=
# The Gulfio Upload-Post account (local-daily.sh points UPLOADPOST_USER at this).
UPLOADPOST_USER_GULFIO=
# UPLOADPOST_USER=        # set automatically from UPLOADPOST_USER_GULFIO by local-daily.sh

# Optional overrides
# CAROUSEL_HOME=/tmp/gulfio
# UPLOADPOST_PLATFORMS=instagram
# CATEGORY=News           # force a pillar: News | Football | Weather | AppValue
# ARTICLE_OFFSET=0        # skip N top articles (avoid repeats)
# SLIDE_WIDTH=768
# SLIDE_HEIGHT=1376
